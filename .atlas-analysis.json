  "keyFeatures": [
    "Microservices architecture with Spring Boot",
    "Service discovery with Netflix Eureka",
    "API Gateway for unified access",
    "Hexagonal architecture (Ports and Adapters pattern)",
    "Multi-database support (PostgreSQL, MySQL, MongoDB)",
    "Docker containerization with docker-compose orchestration",
    "OpenFeign for inter-service communication",
    "Spring Cloud Config for centralized configuration"
  ],
  "publicApiSurface": [
    "GET /api/v1/inventory - List all products with stock",
    "GET /api/v1/inventory/{id} - Get product details by ID",
    "POST /api/v1/inventory - Create new product",
    "POST /api/v1/inventory/{id}/addStock - Add stock to product",
    "POST /api/v1/inventory/{id}/reserveStock - Reserve stock for order",
    "POST /api/v1/inventory/{id}/releaseStock - Release reserved stock",
    "POST /api/v1/inventory/{id}/consumeStock - Consume stock after shipment",
    "Eureka Server - http://localhost:8761",
    "API Gateway - http://localhost:8080",
    "Config Server - http://localhost:8888"
  ]
}
